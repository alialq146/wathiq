# Postgres connection string. On Vercel, adding a Vercel Postgres / Neon
# database injects this automatically (as DATABASE_URL or POSTGRES_PRISMA_URL).
# Locally, copy this file to `.env` and paste your own connection string.
#
# Without a database configured, the app still runs using built-in mock data.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# Claude API key — enables real document analysis. Without it, the analysis
# screen shows a "connect a key" notice. Never commit a real key.
ANTHROPIC_API_KEY="sk-ant-..."

# ---- Per-plan AI model routing (optional) ----
# Each plan is analyzed with a different Claude model to balance cost/quality.
# These are OPTIONAL — if unset, sensible defaults are used:
#   FREE  -> claude-haiku-4-5-20251001  (cheapest)
#   PRO   -> claude-sonnet-5            (balanced)
#   ENTERPRISE -> claude-opus-4-8       (most capable)
# Override any of them here (or in Vercel env) to change routing without code.
AI_MODEL_FREE=""
AI_MODEL_PRO=""
AI_MODEL_ENTERPRISE=""

# ---- Accounts & sign-in ----
# When a database URL is configured (above), the full account system turns on
# automatically: visitors sign up at /signup, sign in at /login, and each
# account gets its own isolated workspace (new accounts start empty).
#
# RECOMMENDED: set a long random string to sign session cookies. If omitted,
# a deployment-specific fallback is derived from the database URL.
WATHIQ_SESSION_SECRET="a-long-random-string"

# ---- Admin dashboard ----
# /admin is restricted to SUPER_ADMIN accounts. Nobody gets the role
# automatically — assign it manually after the user signs up:
#   node scripts/make-admin.mjs admin@example.com
# Optional: SAR conversion rate used for the admin cost estimates.
USD_TO_SAR="3.75"

# ---- Password reset email (optional until configured) ----
# Reset emails are sent via Resend (https://resend.com). Without these,
# nothing breaks: the reset request logs `email_provider_not_configured`
# internally and the user still sees the same generic message.
#   APP_URL         Public origin used to build reset links,
#                   e.g. "https://wathiq-ai.vercel.app" (falls back to VERCEL_URL).
#   EMAIL_FROM      Sender identity, e.g. "وثّق <no-reply@yourdomain.com>".
#   RESEND_API_KEY  Resend API key. Never commit a real key.
APP_URL=""
EMAIL_FROM=""
RESEND_API_KEY=""

# ---- Owner mode (optional, only for DB-less deployments) ----
# With no database, you can still lock the app behind a single fixed
# credential by setting both of these. Leave empty otherwise.
WATHIQ_AUTH_EMAIL=""
WATHIQ_AUTH_PASSWORD=""

# ---- Billing emails (v2.0 — optional, off by default) ----
# Invoices/renewal/expiry emails reuse the same Resend adapter above.
# They stay OFF until you explicitly set BILLING_EMAIL_ENABLED=true
# (and RESEND_API_KEY + EMAIL_FROM are configured). Nothing breaks while off.
BILLING_EMAIL_ENABLED="false"

# ---- Subscription lifecycle cron (v2.0 — optional) ----
# /api/cron/subscription-reminders is DISABLED entirely until this secret is
# set. When you enable Vercel Cron later, set a long random value here and
# send it as "Authorization: Bearer <secret>". Until then, the same lifecycle
# processing runs automatically whenever the admin billing tab is opened.
CRON_SECRET=""
