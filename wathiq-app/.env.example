# Postgres connection string. On Vercel, adding a Vercel Postgres / Neon
# database injects this automatically (as DATABASE_URL or POSTGRES_PRISMA_URL).
# Locally, copy this file to `.env` and paste your own connection string.
#
# Without a database configured, the app still runs using built-in mock data.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# Claude API key — enables real document analysis. Without it, the analysis
# screen shows a "connect a key" notice. Never commit a real key.
ANTHROPIC_API_KEY="sk-ant-..."

# ---- Accounts & sign-in ----
# When a database URL is configured (above), the full account system turns on
# automatically: visitors sign up at /signup, sign in at /login, and each
# account sees its own requirements (plus the shared demo data).
#
# RECOMMENDED: set a long random string to sign session cookies. If omitted,
# a deployment-specific fallback is derived from the database URL.
WATHIQ_SESSION_SECRET="a-long-random-string"

# ---- Owner mode (optional, only for DB-less deployments) ----
# With no database, you can still lock the app behind a single fixed
# credential by setting both of these. Leave empty otherwise.
WATHIQ_AUTH_EMAIL=""
WATHIQ_AUTH_PASSWORD=""
