// Wathiq workspace — data model.
// Mirrors the shapes in src/lib/data.ts so the UI is unchanged whether data
// comes from this database or the in-code fallback.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// A registered account. Passwords are stored as scrypt hashes, never plain.
model User {
  id                 String    @id @default(cuid())
  name               String
  email              String    @unique
  passwordHash       String
  plan               String    @default("FREE") // FREE | PRO | ENTERPRISE
  analysisCount      Int       @default(0)
  analysisLimit      Int       @default(3)
  subscriptionStatus String    @default("ACTIVE") // ACTIVE | INACTIVE | TRIALING | CANCELED | MANUAL
  resetDate          DateTime? // when the monthly analysis counter resets
  role               String    @default("USER") // USER | ADMIN | SUPER_ADMIN — never self-assigned
  accountStatus      String    @default("ACTIVE") // ACTIVE | DISABLED
  limitOverride      Boolean   @default(false) // true → analysisLimit is an admin-set custom cap
  createdAt          DateTime  @default(now())
}

/// رمز استعادة كلمة المرور — يُخزَّن كبصمة (hash) فقط، صالح ٦٠ دقيقة،
/// ويُستخدم مرة واحدة (usedAt). الرمز الخام لا يُحفظ ولا يُسجَّل أبدًا.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

/// One row per AI analysis attempt (success or blocked) — for cost/usage
/// monitoring. Token/cost fields are nullable when the model omits usage.
model AiUsage {
  id            String   @id @default(cuid())
  userId        String
  projectId     String?
  requirementId String?
  documentId    String?
  modelUsed     String
  inputTokens   Int?
  outputTokens  Int?
  estimatedCost Float?
  status        String // SUCCESS | FAILED | BLOCKED_LIMIT | BLOCKED_AUTH | BLOCKED_SIZE
  errorMessage  String?
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([projectId])
  @@index([requirementId])
  @@index([createdAt])
}

/// A workspace/project. Requirements and analyses belong to exactly one.
model Project {
  id          String   @id @default(cuid())
  ownerId     String
  name        String
  code        String
  description String?
  domain      String?
  client      String?
  status      String   @default("active") // draft | active | completed
  color       String?
  icon        String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  // سياق المشروع (اختياري بالكامل) — يحسّن دقة مساعد وثّق ووثائق BRD/SRS.
  // المشاريع القديمة تبقى بقيم فارغة وتعمل طبيعيًا.
  projectIdea    String?
  projectGoal    String?
  targetUsers    String?
  projectScope   String?
  outOfScope     String?
  relatedSystems String?
  constraints    String?

  @@index([ownerId])
}

/// وحدة داخل مشروع (اختيارية) — لتنظيم متطلبات المشاريع الكبيرة.
/// المتطلب يرتبط بوحدة عبر Requirement.moduleId (nullable).
model ProjectModule {
  id          String   @id @default(cuid())
  ownerId     String?
  projectId   String
  name        String
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
  @@index([ownerId])
}

model Requirement {
  id            String   @id
  ownerId       String?
  projectId     String?
  title         String
  description   String
  status        String
  priority      String
  type          String?
  confidence    Int?
  criteria      Int
  openQuestions Int
  module        String
  stakeholders  String[]
  notes         String?
  source        String? // مصدر المتطلب: عميل | اجتماع | وثيقة | بريد | ورشة عمل | أخرى
  assignee      String? // مالك المتطلب / المسؤول عنه
  version       Int      @default(1) // إصدار المتطلب — يرفعه المستخدم يدويًا عند تغيير جوهري
  moduleId      String? // وحدة المشروع (اختيارية) — null للمتطلبات العامة والقديمة
  analysis      Json?
  order         Int      @default(0)

  @@index([ownerId])
  @@index([projectId])
  @@index([moduleId])
}

model AcceptanceCriterion {
  id            String  @id
  ownerId       String?
  projectId     String?
  requirementId String?
  text          String
  done          Boolean
  ai            Boolean
  order         Int     @default(0)

  @@index([requirementId])
  @@index([ownerId])
  @@index([projectId])
}

model BusinessRule {
  id            String  @id
  ownerId       String?
  projectId     String?
  requirementId String?
  text          String
  source        String
  order         Int     @default(0)

  @@index([requirementId])
  @@index([ownerId])
  @@index([projectId])
}

model OpenQuestion {
  id            String  @id
  ownerId       String?
  projectId     String?
  requirementId String?
  text          String
  to            String
  ai            Boolean
  answer        String?
  order         Int     @default(0)

  @@index([requirementId])
  @@index([ownerId])
  @@index([projectId])
}

/// Append-only activity log for the audit trail screen.
model AuditEvent {
  id            String   @id @default(cuid())
  ownerId       String?
  projectId     String?
  requirementId String?
  action        String
  detail        String
  actor         String   @default("سارة العتيبي")
  createdAt     DateTime @default(now())

  @@index([requirementId])
  @@index([createdAt])
  @@index([ownerId])
  @@index([projectId])
}

/// ملاحظات المستخدمين من داخل المنصة (v1.9.11) — قناة تحسين ما بعد الإطلاق.
/// لا تحفظ أسرارًا ولا محتوى صفحات؛ فقط ما أدخله المستخدم + سياق خفيف.
model UserFeedback {
  id            String   @id @default(cuid())
  userId        String
  type          String // مشكلة | اقتراح | صعوبة في الاستخدام | طلب ميزة | أخرى
  severity      String // عادي | مهم | عاجل
  message       String
  currentPath   String?
  projectId     String?
  requirementId String?
  plan          String?
  userAgent     String?
  status        String   @default("open") // open | in_review | closed
  adminNote     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([userId])
}

/// أحداث استخدام المنتج (v1.9.11) — تخزين داخلي خفيف بلا أدوات خارجية.
/// metadata خفيفة فقط (نوع مهمة/نوع تصدير/عدادات) — لا نصوص متطلبات ولا وثائق.
model ProductEvent {
  id            String   @id @default(cuid())
  userId        String?
  eventName     String
  plan          String?
  projectId     String?
  requirementId String?
  metadata      Json?
  createdAt     DateTime @default(now())

  @@index([eventName, createdAt])
  @@index([createdAt])
  @@index([userId])
}
