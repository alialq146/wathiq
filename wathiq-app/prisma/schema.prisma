// Wathiq workspace — data model.
// Mirrors the shapes in src/lib/data.ts so the UI is unchanged whether data
// comes from this database or the in-code fallback.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// A registered account. Passwords are stored as scrypt hashes, never plain.
model User {
  id                 String    @id @default(cuid())
  name               String
  email              String    @unique
  passwordHash       String
  plan               String    @default("FREE") // FREE | PRO | ENTERPRISE
  analysisCount      Int       @default(0)
  analysisLimit      Int       @default(3)
  subscriptionStatus String    @default("ACTIVE") // ACTIVE | INACTIVE | TRIALING | CANCELED | MANUAL
  resetDate          DateTime? // when the monthly analysis counter resets
  role               String    @default("USER") // USER | ADMIN | SUPER_ADMIN — never self-assigned
  accountStatus      String    @default("ACTIVE") // ACTIVE | DISABLED
  limitOverride      Boolean   @default(false) // true → analysisLimit is an admin-set custom cap
  createdAt          DateTime  @default(now())
}

/// رمز استعادة كلمة المرور — يُخزَّن كبصمة (hash) فقط، صالح ٦٠ دقيقة،
/// ويُستخدم مرة واحدة (usedAt). الرمز الخام لا يُحفظ ولا يُسجَّل أبدًا.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

/// One row per AI analysis attempt (success or blocked) — for cost/usage
/// monitoring. Token/cost fields are nullable when the model omits usage.
model AiUsage {
  id            String   @id @default(cuid())
  userId        String
  projectId     String?
  requirementId String?
  documentId    String?
  modelUsed     String
  inputTokens   Int?
  outputTokens  Int?
  estimatedCost Float?
  status        String // SUCCESS | FAILED | BLOCKED_LIMIT | BLOCKED_AUTH | BLOCKED_SIZE
  errorMessage  String?
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([projectId])
  @@index([requirementId])
  @@index([createdAt])
}

/// A workspace/project. Requirements and analyses belong to exactly one.
model Project {
  id          String   @id @default(cuid())
  ownerId     String
  name        String
  code        String
  description String?
  domain      String?
  client      String?
  status      String   @default("active") // draft | active | completed
  color       String?
  icon        String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  // سياق المشروع (اختياري بالكامل) — يحسّن دقة مساعد وثّق ووثائق BRD/SRS.
  // المشاريع القديمة تبقى بقيم فارغة وتعمل طبيعيًا.
  projectIdea    String?
  projectGoal    String?
  targetUsers    String?
  projectScope   String?
  outOfScope     String?
  relatedSystems String?
  constraints    String?

  // الوثائق والمخرجات (v2.3): REQUIRED | OPTIONAL | NOT_APPLICABLE.
  // ليست Boolean عمدًا — الاختيارية تبقى ظاهرة بلا أثر على الجاهزية،
  // وغير المطلوبة تُخفى كليًا (منطقيًا فقط؛ لا حذف بيانات أبدًا).
  // الافتراضي REQUIRED للوثيقتين = سلوك المنصة قبل v2.3 حرفيًا.
  brdApplicability String @default("REQUIRED")
  srsApplicability String @default("REQUIRED")

  @@index([ownerId])
}

/// وحدة داخل مشروع (اختيارية) — لتنظيم متطلبات المشاريع الكبيرة.
/// المتطلب يرتبط بوحدة عبر Requirement.moduleId (nullable).
model ProjectModule {
  id          String   @id @default(cuid())
  ownerId     String?
  projectId   String
  name        String
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
  @@index([ownerId])
}

model Requirement {
  id            String   @id
  ownerId       String?
  projectId     String?
  title         String
  description   String
  status        String
  priority      String
  type          String?
  confidence    Int?
  criteria      Int
  openQuestions Int
  module        String
  stakeholders  String[]
  notes         String?
  source        String? // مصدر المتطلب: عميل | اجتماع | وثيقة | بريد | ورشة عمل | أخرى
  assignee      String? // مالك المتطلب / المسؤول عنه
  version       Int      @default(1) // إصدار المتطلب — يرفعه المستخدم يدويًا عند تغيير جوهري
  moduleId      String? // وحدة المشروع (اختيارية) — null للمتطلبات العامة والقديمة
  analysis      Json?
  order         Int      @default(0)

  @@index([ownerId])
  @@index([projectId])
  @@index([moduleId])
}

model AcceptanceCriterion {
  id            String  @id
  ownerId       String?
  projectId     String?
  requirementId String?
  text          String
  done          Boolean
  ai            Boolean
  order         Int     @default(0)

  @@index([requirementId])
  @@index([ownerId])
  @@index([projectId])
}

model BusinessRule {
  id            String  @id
  ownerId       String?
  projectId     String?
  requirementId String?
  text          String
  source        String
  order         Int     @default(0)

  @@index([requirementId])
  @@index([ownerId])
  @@index([projectId])
}

model OpenQuestion {
  id            String  @id
  ownerId       String?
  projectId     String?
  requirementId String?
  text          String
  to            String
  ai            Boolean
  answer        String?
  order         Int     @default(0)

  @@index([requirementId])
  @@index([ownerId])
  @@index([projectId])
}

/// Append-only activity log for the audit trail screen.
model AuditEvent {
  id            String   @id @default(cuid())
  ownerId       String?
  projectId     String?
  requirementId String?
  action        String
  detail        String
  actor         String   @default("سارة العتيبي")
  createdAt     DateTime @default(now())

  @@index([requirementId])
  @@index([createdAt])
  @@index([ownerId])
  @@index([projectId])
}

/// ملاحظات المستخدمين من داخل المنصة (v1.9.11) — قناة تحسين ما بعد الإطلاق.
/// لا تحفظ أسرارًا ولا محتوى صفحات؛ فقط ما أدخله المستخدم + سياق خفيف.
model UserFeedback {
  id            String   @id @default(cuid())
  userId        String
  type          String // مشكلة | اقتراح | صعوبة في الاستخدام | طلب ميزة | أخرى
  severity      String // عادي | مهم | عاجل
  message       String
  currentPath   String?
  projectId     String?
  requirementId String?
  plan          String?
  userAgent     String?
  status        String   @default("open") // open | in_review | closed
  adminNote     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([userId])
}

/// أحداث استخدام المنتج (v1.9.11) — تخزين داخلي خفيف بلا أدوات خارجية.
/// metadata خفيفة فقط (نوع مهمة/نوع تصدير/عدادات) — لا نصوص متطلبات ولا وثائق.
model ProductEvent {
  id            String   @id @default(cuid())
  userId        String?
  eventName     String
  plan          String?
  projectId     String?
  requirementId String?
  metadata      Json?
  createdAt     DateTime @default(now())

  @@index([eventName, createdAt])
  @@index([createdAt])
  @@index([userId])
}

/* ============================================================
   الفوترة والاشتراكات (v2.0) — Billing & Subscriptions
   المبدأ: User.plan يبقى مصدر الحقيقة لقرارات الحصة والتوجيه
   (لا نلمس منطق v1.9.7)، وSubscription هو السجل المالي والزمني.
   تفعيل/تجديد الاشتراك يحدّث User.plan داخل نفس المعاملة الذرية.
   ============================================================ */

/// الاشتراك — سجل زمني ومالي واحد لكل مستخدم (يُحدَّث عند التجديد،
/// والتاريخ الكامل محفوظ في Payments/Invoices/BillingAuditLog).
/// «قارب على الانتهاء» حالة محسوبة من endDate — لا تُخزَّن لتجنب عدم التزامن.
/// الاشتراك (v2.1) — سجل تاريخي: كل فترة صف مستقل لا يُكتب فوقه.
/// «الاشتراك الحالي» يُحسب لا يُخزَّن: أحدث صف ACTIVE يشمل تاريخ اليوم
/// (getCurrentSubscription). التجديد ينشئ صفًا جديدًا ويربطه بـ renewedFromId
/// ويُنهي/يستبدل السابق — لا فقد تاريخ. حالة SCHEDULED للتجديد المبكر حتى
/// لا يوجد اشتراكان ACTIVE في وقت واحد (يحوّله syncSubscriptionStatuses).
model Subscription {
  id                     String    @id @default(cuid())
  userId                 String
  plan                   String // FREE | PRO | ENTERPRISE
  status                 String    @default("ACTIVE") // TRIAL | SCHEDULED | ACTIVE | EXPIRED | CANCELED | SUSPENDED | SUPERSEDED
  billingCycle           String    @default("MONTHLY") // MONTHLY | YEARLY | CUSTOM
  startDate              DateTime
  endDate                DateTime
  price                  Decimal   @db.Decimal(10, 2)
  currency               String    @default("SAR")
  autoRenew              Boolean   @default(false) // غير مفعل حاليًا — جاهز للبوابات لاحقًا
  source                 String    @default("MANUAL") // MANUAL | PAYMENT_GATEWAY | ADMIN_GRANT | TRIAL | MIGRATED
  previousSubscriptionId String? // السجل الذي سبقه زمنيًا لهذا المستخدم
  renewedFromId          String? // السجل الذي جُدِّد منه (للتتبع)
  canceledAt             DateTime?
  cancellationReason     String?
  supersededAt           DateTime? // وقت استبداله بتغيير خطة فوري
  createdByAdminId       String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([userId, createdAt])
  @@index([userId, status])
  @@index([endDate, status])
  @@index([renewedFromId])
}

/// الفاتورة — snapshot لبيانات العميل وقت الإصدار حتى لا تتغير الفواتير
/// التاريخية لو عدّل المستخدم اسمه لاحقًا. internalNote للأدمن فقط ولا
/// يُرسَل للعميل أبدًا. الضريبة قابلة للتهيئة — لا قيمة مفترضة في الكود.
model Invoice {
  id                           String    @id @default(cuid())
  invoiceNumber                String    @unique
  userId                       String
  subscriptionId               String?
  status                       String    @default("PENDING") // DRAFT | PENDING | PAID | OVERDUE | CANCELED | REFUNDED
  issueDate                    DateTime  @default(now())
  dueDate                      DateTime?
  paidAt                       DateTime?
  subtotal                     Decimal   @db.Decimal(10, 2)
  discount                     Decimal   @default(0) @db.Decimal(10, 2)
  taxAmount                    Decimal   @default(0) @db.Decimal(10, 2)
  total                        Decimal   @db.Decimal(10, 2)
  currency                     String    @default("SAR")
  billingPeriodStart           DateTime?
  billingPeriodEnd             DateTime?
  customerNameSnapshot         String
  customerEmailSnapshot        String
  customerOrganizationSnapshot String?
  // Snapshot الجهة المصدرة والإعدادات وقت الإصدار (v2.1) — الفواتير التاريخية
  // ثابتة لا تتأثر بأي تعديل لاحق على إعدادات الفوترة.
  issuerNameSnapshot           String?
  issuerLegalNameSnapshot      String?
  issuerEmailSnapshot          String?
  issuerPhoneSnapshot          String?
  issuerAddressSnapshot        String?
  issuerTaxNumberSnapshot      String?
  issuerCrSnapshot             String? // السجل التجاري
  footerTextSnapshot           String?
  paymentInstructionsSnapshot  String?
  taxLabelSnapshot             String?
  taxRateSnapshot              Decimal? @db.Decimal(5, 2) // نسبة الضريبة المطبقة وقت الإصدار
  notes                        String? // تظهر للعميل
  internalNote                 String? // للأدمن فقط — لا تُعرض للعميل إطلاقًا
  createdByAdminId             String?
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([issueDate])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  description String
  quantity    Int      @default(1)
  unitPrice   Decimal  @db.Decimal(10, 2)
  total       Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())

  @@index([invoiceId])
}

/// الدفعة — نقدًا/تحويلًا حاليًا، والحقول provider/providerPaymentId جاهزة
/// لبوابات الدفع مستقبلًا دون تغيير المخطط. لا بيانات بطاقات تُخزَّن أبدًا.
model Payment {
  id                String    @id @default(cuid())
  userId            String
  invoiceId         String?
  subscriptionId    String?
  amount            Decimal   @db.Decimal(10, 2)
  currency          String    @default("SAR")
  method            String // CASH | BANK_TRANSFER | MANUAL | CARD | PAYMENT_GATEWAY | OTHER
  status            String    @default("COMPLETED") // PENDING | COMPLETED | FAILED | REFUNDED | CANCELED
  paidAt            DateTime  @default(now())
  referenceNumber   String?
  receivedByAdminId String?
  notes             String?
  provider          String?
  providerPaymentId String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId])
  @@index([invoiceId])
  @@index([paidAt])
}

/// تذكيرات انتهاء الاشتراك — scheduledFor مشتق من endDate، والقيد الفريد
/// (subscriptionId + type + scheduledFor) يمنع تكرار نفس التذكير لنفس الفترة
/// حتى بعد التجديد (فترة جديدة → scheduledFor جديد → صف جديد مسموح).
model SubscriptionReminder {
  id             String    @id @default(cuid())
  userId         String
  subscriptionId String
  type           String // EXPIRY_7_DAYS | EXPIRY_3_DAYS | EXPIRY_1_DAY | EXPIRED | ADMIN_FOLLOW_UP
  scheduledFor   DateTime
  sentAt         DateTime?
  channel        String    @default("IN_APP") // IN_APP | EMAIL
  status         String    @default("PENDING") // PENDING | SENT | SKIPPED | FAILED
  errorMessage   String?
  createdAt      DateTime  @default(now())

  @@unique([subscriptionId, type, scheduledFor, channel])
  @@index([userId])
  @@index([status, scheduledFor])
}

/// سجل تدقيق مالي منفصل — كل عملية اشتراك/فاتورة/دفعة تُسجَّل مع منفذها.
/// metadata خفيفة (خطة/مبلغ/حالة) — لا أسرار ولا بيانات بطاقات.
model BillingAuditLog {
  id         String   @id @default(cuid())
  actorId    String? // الأدمن المنفذ (null للعمليات الآلية كانتهاء الاشتراك)
  userId     String
  entityType String // SUBSCRIPTION | INVOICE | PAYMENT | REMINDER | EMAIL
  entityId   String?
  action     String // SUBSCRIPTION_CREATED | SUBSCRIPTION_RENEWED | ... | BILLING_EMAIL_SENT
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

/// بيانات الفوترة الاختيارية — تُستخدم كـ snapshot عند إصدار الفواتير.
/// وجود الرقم الضريبي لا يجعل الفاتورة «ضريبية» — ذلك يتطلب اعتمادًا صريحًا.
model CustomerBillingProfile {
  userId                 String   @id
  legalName              String?
  organizationName       String?
  taxNumber              String?
  commercialRegistration String?
  address                String?
  city                   String?
  country                String?
  billingEmail           String?
  phone                  String?
  internalNote           String? // ملاحظات أدمن داخلية عن العميل — لا تُعرض له
  updatedAt              DateTime @updatedAt
}

/// عدّاد أرقام الفواتير لكل سنة — increment ذري داخل معاملة يضمن التفرد
/// حتى مع الطلبات المتزامنة (لا نعتمد على count+1 إطلاقًا).
model InvoiceCounter {
  year  Int @id
  value Int @default(0)
}

/// إعدادات الفوترة المركزية (v2.1) — صف واحد ثابت المعرّف ("singleton").
/// كل الحقول قابلة للتعديل من الأدمن دون لمس الكود. لا أسرار هنا إطلاقًا
/// (مفاتيح البريد/الدفع/Cron تبقى Environment Variables).
/// ملاحظة: تفعيل الضريبة إعداد حسابي فقط ولا يمثل اعتمادًا ضريبيًا رسميًا.
model BillingSettings {
  id                      String   @id @default("singleton")
  issuerName              String   @default("وثّق")
  issuerLegalName         String?
  issuerEmail             String?
  issuerPhone             String?
  issuerAddress           String?
  issuerCity              String?
  issuerCountry           String?
  issuerTaxNumber         String?
  issuerCommercialRegistration String?
  logoUrl                 String?
  defaultCurrency         String   @default("SAR")
  taxEnabled              Boolean  @default(false)
  defaultTaxRate          Decimal  @default(0) @db.Decimal(5, 2)
  taxLabel                String   @default("ضريبة القيمة المضافة")
  invoicePrefix           String   @default("INV")
  invoiceFooterText       String   @default("شكرًا لاستخدامك وثّق.")
  invoiceNotes            String?
  defaultDueDays          Int      @default(0)
  paymentInstructions     String?
  showPaymentMethod       Boolean  @default(true)
  showReferenceNumber     Boolean  @default(true)
  supportEmail            String?
  supportPhone            String?
  updatedByAdminId        String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

// ═══════════ إعدادات النظام المركزية (v2.2) ═══════════
// صف singleton واحد؛ كل مجموعة إعدادات عمود JSON typed يُدمج فوق القيم
// الافتراضية الآمنة في الكود (src/lib/settings/defaults.ts) — غياب السجل أو
// الحقل يعني السلوك الافتراضي الحالي حرفيًا. لا أسرار هنا إطلاقًا:
// المفاتيح (AI/DB/Session/Cron/Resend/بوابات الدفع) تبقى Environment Variables.
model SystemSettings {
  id               String   @id @default("singleton")
  schemaVersion    Int      @default(1)
  general          Json? // اسم المنصة، الفوتر، اللغة/المنطقة الزمنية…
  contact          Json? // واتساب، بريد الدعم/المبيعات، نصوص الترقية/التجديد…
  notifications    Json? // أيام تذكير الاشتراك وتفعيلاتها ونصوصها
  documents        Json? // نصوص وأقسام BRD/SRS/التقرير والطباعة
  plans            Json? // عرض وحدود الخطط (بسقوف صلبة في الكود)
  assistant        Json? // مهام مساعد وثّق وحدودها (SUPER_ADMIN فقط)
  features         Json? // Feature flags آمنة (التسجيل/الصيانة/Demo…)
  readiness        Json? // مركز جاهزية المشروع والوثائق (v2.3)
  updatedByAdminId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// سجل تدقيق تغييرات الإعدادات — من عدّل، أي قسم، أي حقول، والقيم
// القديمة/الجديدة مقصوصة بأمان (لا secrets ولا نصوص كاملة طويلة).
model SettingsAuditLog {
  id          String   @id @default(cuid())
  adminId     String
  section     String // GENERAL | CONTACT | NOTIFICATIONS | DOCUMENTS | PLANS | ASSISTANT | FEATURES | RESET
  action      String // *_SETTINGS_UPDATED | SETTINGS_RESET_TO_DEFAULT
  changedKeys Json? // ["platformName", ...]
  diff        Json? // { key: { old, new } } — قيم مقصوصة
  reason      String?
  createdAt   DateTime @default(now())

  @@index([section, createdAt])
  @@index([createdAt])
}


// ═══════════ مركز جاهزية المشروع والوثائق (v2.3) ═══════════
// لقطة الجاهزية — سجل تاريخي خفيف (النتيجة تُحسب دائمًا من البيانات الحية؛
// اللقطة للتتبع وعرض «آخر احتساب» بلا إعادة حساب عند كل فتح).
// درجات BRD/SRS تكون null عندما تكون الوثيقة غير مطلوبة — لا صفر أبدًا.
model ReadinessSnapshot {
  id                   String   @id @default(cuid())
  projectId            String
  ownerId              String
  overallScore         Int
  brdScore             Int?
  srsScore             Int?
  criticalIssuesCount  Int      @default(0)
  importantIssuesCount Int      @default(0)
  optionalIssuesCount  Int      @default(0)
  calculationVersion   Int      @default(1)
  settingsVersion      Int      @default(1) // schemaVersion لإعدادات النظام وقت الحساب
  issues               Json? // [{ code, severity, scope, entityType, entityId, count }] — مقصوصة، لا نصوص متطلبات
  calculatedAt         DateTime @default(now())
  createdAt            DateTime @default(now())

  @@index([projectId, calculatedAt])
  @@index([ownerId])
}

// سجل تصدير الوثائق مع الجاهزية — من صدّر ماذا وبأي درجة وبأي تحذيرات.
model ReadinessExportLog {
  id                  String   @id @default(cuid())
  projectId           String
  userId              String
  documentType        String // BRD | SRS
  readinessScore      Int?
  criticalIssuesCount Int      @default(0)
  exportedWithWarnings Boolean @default(false)
  blocked             Boolean  @default(false) // محاولة مُنعت (سياسة block)
  exportedAt          DateTime @default(now())

  @@index([projectId, exportedAt])
  @@index([userId])
}
