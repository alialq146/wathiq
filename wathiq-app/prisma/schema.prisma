// Wathiq workspace — data model.
// Mirrors the shapes in src/lib/data.ts so the UI is unchanged whether data
// comes from this database or the in-code fallback.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// A registered account. Passwords are stored as scrypt hashes, never plain.
model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Requirement {
  id            String  @id
  ownerId       String?
  title         String
  description   String
  status        String
  priority      String
  confidence    Int?
  criteria      Int
  openQuestions Int
  module        String
  stakeholders  String[]
  order         Int     @default(0)

  @@index([ownerId])
}

model AcceptanceCriterion {
  id            String  @id
  ownerId       String?
  requirementId String?
  text          String
  done          Boolean
  ai            Boolean
  order         Int     @default(0)

  @@index([requirementId])
  @@index([ownerId])
}

model BusinessRule {
  id            String  @id
  ownerId       String?
  requirementId String?
  text          String
  source        String
  order         Int     @default(0)

  @@index([requirementId])
  @@index([ownerId])
}

model OpenQuestion {
  id            String  @id
  ownerId       String?
  requirementId String?
  text          String
  to            String
  ai            Boolean
  answer        String?
  order         Int     @default(0)

  @@index([requirementId])
  @@index([ownerId])
}

/// Append-only activity log for the audit trail screen.
model AuditEvent {
  id            String   @id @default(cuid())
  ownerId       String?
  requirementId String?
  action        String
  detail        String
  actor         String   @default("سارة العتيبي")
  createdAt     DateTime @default(now())

  @@index([requirementId])
  @@index([createdAt])
  @@index([ownerId])
}
